# ═══════════════════════════════════════════════════════════════════
#  seo-audit-runner — configuration
#  Copy to .env in this directory (never commit .env).
#
#  SECURITY: the application API has NO authentication. SEO_API_BASE_URL
#  must point to a trusted PRIVATE endpoint: localhost, a Docker network
#  hostname, or a VPN/internal address. Plain-http URLs to public hosts
#  are rejected unless ALLOW_INSECURE_PUBLIC_API=true (development only).
# ═══════════════════════════════════════════════════════════════════

# Base URL of the running SEO analyzer app (origin only, no path).
SEO_API_BASE_URL=http://localhost:3000

# Max audits running in parallel across DIFFERENT sites. Keep low: the app
# runs audits in-process and has no job queue. Same-site runs are never
# parallelized (the audit endpoint replaces the site's seed_urls).
RUNNER_CONCURRENCY=1

# Polling cadence and per-audit timeout.
POLL_INTERVAL_MS=5000
POLL_TIMEOUT_MS=900000

# Timeout for each individual HTTP request to the SEO app.
HTTP_REQUEST_TIMEOUT_MS=30000

# Directory for runtime state: process lock + run report journal.
# Default when unset: <this package>/state
# Production suggestion:
# RUNNER_STATE_DIR=/var/lib/seo-audit-runner

# Runner-owned SQLite state database (issue lifecycle + notification queue).
# Default when unset: <RUNNER_STATE_DIR>/runner-state.sqlite
# RUNNER_STATE_DB_PATH=/var/lib/seo-audit-runner/runner-state.sqlite

# error | warn | info | debug
RUNNER_LOG_LEVEL=info

# ── Notifications (Phase 3) ─────────────────────────────────────────
# Master switch. When false, no Slack messages are sent (issue lifecycle
# state is still tracked after successful audits).
NOTIFICATIONS_ENABLED=false

# Alert mode: new_or_regressed (default) | all_current | summary_only | disabled
#   new_or_regressed — notify only on new / reopened / resolved P0 issues
#   all_current      — list all current P0 issues plus lifecycle counts
#   summary_only     — counts only, no individual issues
#   disabled         — never notify (state is still updated)
SEO_RUNNER_ALERT_MODE=new_or_regressed

# Send one end-of-execution summary message.
SEO_RUNNER_SEND_RUN_SUMMARY=true

# ── Slack delivery (values below are FAKE examples) ─────────────────
# Preferred method: bot token + explicit channel ID (both required).
# The bot needs the chat:write scope and must be invited to the channel.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Bot tokens start with "xoxb-" followed by your app's numeric IDs (find it
# under OAuth & Permissions in your Slack app). Never commit the real value.
# Example (placeholder): SLACK_CHANNEL_ID=C0123456789

# Fallback method: incoming webhook (used only when no bot token is set).
SLACK_WEBHOOK_URL=
# Webhook URLs look like https://hooks.slack.com/services/<workspace>/<channel>/<secret>
# Never commit the real value.

# Slack reliability and formatting limits.
SLACK_REQUEST_TIMEOUT_MS=15000
SLACK_MAX_RETRIES=4
SLACK_MAX_ISSUES_PER_MESSAGE=20
SLACK_MAX_MESSAGE_CHARACTERS=30000

# Optional link included in project notifications (e.g. your dashboard).
# SEO_RUNNER_DASHBOARD_URL=

# ── Development-only overrides ─────────────────────────────────────
# Allow plain-http SEO_API_BASE_URL pointing at a public host. NEVER
# enable in production.
# ALLOW_INSECURE_PUBLIC_API=false
