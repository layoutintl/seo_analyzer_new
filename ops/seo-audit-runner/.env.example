# ═══════════════════════════════════════════════════════════════════
#  seo-audit-runner — configuration
#  Copy to .env in this directory (never commit .env).
#
#  SECURITY: the application API has NO authentication. SEO_API_BASE_URL
#  must point to a trusted PRIVATE endpoint: localhost, a Docker network
#  hostname, or a VPN/internal address. Plain-http URLs to public hosts
#  are rejected unless ALLOW_INSECURE_PUBLIC_API=true (development only).
# ═══════════════════════════════════════════════════════════════════

# Base URL of the running SEO analyzer app (origin only, no path).
SEO_API_BASE_URL=http://localhost:3000

# Max audits running in parallel across DIFFERENT sites. Keep low: the app
# runs audits in-process and has no job queue. Same-site runs are never
# parallelized (the audit endpoint replaces the site's seed_urls).
RUNNER_CONCURRENCY=1

# Polling cadence and per-audit timeout.
POLL_INTERVAL_MS=5000
POLL_TIMEOUT_MS=900000

# Timeout for each individual HTTP request.
HTTP_REQUEST_TIMEOUT_MS=30000

# Directory for runtime state: process lock + run report journal.
# Default when unset: <this package>/state
# Production suggestion:
# RUNNER_STATE_DIR=/var/lib/seo-audit-runner

# error | warn | info | debug
RUNNER_LOG_LEVEL=info

# ── Notifications (Phase 2: optional, disabled by default) ─────────
# When true, a Slack Incoming Webhook digest is sent after each run.
NOTIFICATIONS_ENABLED=false
# Required only when NOTIFICATIONS_ENABLED=true. Treated as a secret —
# never logged.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Development-only overrides ─────────────────────────────────────
# Allow plain-http SEO_API_BASE_URL pointing at a public host. NEVER
# enable in production.
# ALLOW_INSECURE_PUBLIC_API=false
