# ═══════════════════════════════════════════════════════════════════
#  seo-audit-runner — production configuration template
#
#  install.sh copies this file to /etc/seo-audit-runner/runner.env
#  ONLY when that file does not exist yet (an existing runner.env is
#  never overwritten). Target permissions: root:seo-runner 0640.
#
#  This template contains NO real credentials — fill in the Slack
#  values on the host, never in the repository.
#
#  SECURITY: the application API has NO authentication. SEO_API_BASE_URL
#  must point to a trusted PRIVATE endpoint: localhost, a Docker network
#  hostname, or a VPN/internal address.
# ═══════════════════════════════════════════════════════════════════

# Base URL of the running SEO analyzer app (origin only, no path).
SEO_API_BASE_URL=http://127.0.0.1:3000

# Max audits running in parallel across DIFFERENT sites. Keep low: the
# app runs audits in-process and has no job queue.
RUNNER_CONCURRENCY=1

# Polling cadence, per-audit timeout, and per-request HTTP timeout.
POLL_INTERVAL_MS=5000
POLL_TIMEOUT_MS=900000
HTTP_REQUEST_TIMEOUT_MS=30000

# Runner-owned durable state (SQLite database, run journals, backups).
# These are the approved production paths — the runner writes nowhere else.
RUNNER_STATE_DIR=/var/lib/seo-audit-runner
RUNNER_STATE_DB_PATH=/var/lib/seo-audit-runner/runner-state.sqlite

# error | warn | info | debug
RUNNER_LOG_LEVEL=info

# ── Notifications ───────────────────────────────────────────────────
# Master switch. NOTE: the template ships with notifications DISABLED
# because enabling them requires a configured Slack delivery method
# below — `seo-audit-runner validate-config` fails otherwise. Set
# NOTIFICATIONS_ENABLED=true after filling in the Slack values.
NOTIFICATIONS_ENABLED=false

# Alert mode: new_or_regressed | all_current | summary_only | disabled
SEO_RUNNER_ALERT_MODE=new_or_regressed

# Send one end-of-execution summary message per run.
SEO_RUNNER_SEND_RUN_SUMMARY=true

# ── Slack delivery (leave empty in the repo; fill in on the host) ───
# Preferred method: bot token + channel ID (both required; the bot needs
# the chat:write scope and must be invited to the channel).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Fallback method: incoming webhook (used only when no bot token is set).
SLACK_WEBHOOK_URL=

# Slack reliability and formatting limits.
SLACK_REQUEST_TIMEOUT_MS=15000
SLACK_MAX_RETRIES=4
SLACK_MAX_ISSUES_PER_MESSAGE=20
SLACK_MAX_MESSAGE_CHARACTERS=30000
