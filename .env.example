# ═══════════════════════════════════════════════════════════════════
#  SEO Analyzer — Environment Variables
#  Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (Supabase — required for persistence) ─────────────────
# Without these the server runs in IN-MEMORY mode (results not saved).
# Get values from: https://supabase.com/dashboard → Settings → API
#
# IMPORTANT: Use SUPABASE_URL (not VITE_) for server-side runtime.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Frontend build-time (Vite) ─────────────────────────────────────
# Vite inlines VITE_* vars into the browser bundle at build time.
# Set to the same values as SUPABASE_URL / SUPABASE_ANON_KEY.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Leave empty for same-origin deployment (Docker / PaaS).
# Set to a full URL only if the API is hosted on a different origin.
VITE_API_BASE_URL=

# ── Optional: Scrapling sidecar ────────────────────────────────────
# URL of the Python Scrapling sidecar for JS-rendered page fetching.
# When unset or unreachable, routes fall back to native fetch().
# Used automatically by docker-compose; set manually for other setups.
# SCRAPLING_SIDECAR_URL=http://localhost:5000

# ── Optional: PageSpeed Insights API key ──────────────────────────
# When set, performance checks include real Core Web Vitals data.
# Get a free key: https://developers.google.com/speed/docs/insights/v5/get-started
# PAGESPEED_API_KEY=
